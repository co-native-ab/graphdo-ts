{
  "name": "graphdo-ts",
  "version": "0.0.0",
  "description": "MCP server providing AI agents with scoped access to Microsoft Graph",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "mcpb": "npm run build && npx @anthropic-ai/mcpb@latest pack . graphdo.mcpb",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "keywords": [
    "mcp",
    "microsoft-graph",
    "ai-agents",
    "graph-api"
  ],
  "author": "co-native-ab",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  }
}
